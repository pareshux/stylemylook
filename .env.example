# Copy to .env.local and fill in values.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Required for POST /api/waitlist (Dashboard → Settings → API → service_role secret)
SUPABASE_SERVICE_ROLE_KEY=

# Optional: confirmation email after waitlist signup (https://resend.com — add in Vercel too)
RESEND_API_KEY=

# Outfit suggestions (https://console.anthropic.com — use the secret key, not a publishable key)
ANTHROPIC_API_KEY=
# Optional override; default is claude-opus-4-5-20251101
# ANTHROPIC_MODEL=
