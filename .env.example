# Copy to .env.local and fill in values.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Required for POST /api/waitlist (Dashboard → Settings → API → service_role secret)
SUPABASE_SERVICE_ROLE_KEY=

# Optional: confirmation email after waitlist signup (https://resend.com — add in Vercel too)
RESEND_API_KEY=

# Outfit suggestions (https://console.anthropic.com — secret key, starts with sk-ant-)
ANTHROPIC_API_KEY=
# Do not set unless you use bearer auth; if set wrongly alongside API key, requests can 401.
# ANTHROPIC_AUTH_TOKEN=
# Optional override; default is claude-opus-4-5-20251101
# ANTHROPIC_MODEL=
