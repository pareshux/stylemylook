# Copy to .env.local and fill in values.

# Invite-only auth mode
# true = block direct /login and /signup unless a valid invite has been accepted
INVITE_ONLY_MODE=false
# Secret used to sign invite access cookie (use a long random string)
AUTH_INVITE_COOKIE_SECRET=
# Secret for calling POST /api/invites/send (use in x-invite-admin or Bearer token)
INVITE_ADMIN_SECRET=
# Optional canonical app URL used in invite emails (fallback: request origin)
NEXT_PUBLIC_SITE_URL=

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Required for POST /api/waitlist (Dashboard → Settings → API → service_role secret)
SUPABASE_SERVICE_ROLE_KEY=

# Optional: confirmation email after waitlist signup (https://resend.com — add in Vercel too)
RESEND_API_KEY=

# Outfit suggestions (https://console.anthropic.com — secret key, starts with sk-ant-)
ANTHROPIC_API_KEY=
# Do not set unless you use bearer auth; if set wrongly alongside API key, requests can 401.
# ANTHROPIC_AUTH_TOKEN=
# Optional override; default is claude-opus-4-5-20251101
# ANTHROPIC_MODEL=

# Razorpay subscriptions (https://razorpay.com — create keys in Dashboard)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Public Razorpay key (safe to expose to client)
NEXT_PUBLIC_RAZORPAY_KEY_ID=

# Razorpay plan IDs created in Razorpay Dashboard
RAZORPAY_PLAN_PRO_MONTHLY=
RAZORPAY_PLAN_PRO_YEARLY=
RAZORPAY_PLAN_PREMIUM_MONTHLY=
RAZORPAY_PLAN_PREMIUM_YEARLY=

# Razorpay webhook secret (use from Webhook settings)
RAZORPAY_WEBHOOK_SECRET=
